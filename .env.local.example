# ── Supabase (obrigatório) ──
# A anon key é pública por design; a segurança dos dados vem das policies de RLS.
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key

# Service role key — SÓ no servidor, NUNCA com prefixo NEXT_PUBLIC_.
# Necessária para a exclusão de conta (LGPD): apaga os dados e o usuário
# de autenticação via API admin. Encontre em Supabase → Project Settings →
# API → service_role. Trate como segredo máximo (acesso total ao banco).
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key

# ── Brapi (opcional — cotações em tempo real) ──
# Token server-side: NÃO use o prefixo NEXT_PUBLIC_ (vazaria no bundle do client).
# Obtenha em: https://brapi.dev
BRAPI_TOKEN=seu_token_brapi

# ── OpenAI (opcional — análise IA da carteira) ──
# Obtenha em: https://platform.openai.com/api-keys
# Custo estimado: ~$0.01-0.03 por análise (gpt-4o-mini)
OPENAI_API_KEY=sua_chave_openai
